# ==============================================================================
# Traefik
# ==============================================================================

# Email address used for Let's Encrypt certificate registration and expiry notices.
ACME_EMAIL=you@example.com

# Username shown on the Traefik dashboard login prompt.
TRAEFIK_DASHBOARD_USER=admin

# Bcrypt/APR1 password hash for the Traefik dashboard.
# Generate with: openssl passwd -apr1 "yourpassword"
# IMPORTANT: every $ in the hash must be doubled ($$) when used in a Docker label.
TRAEFIK_DASHBOARD_PASSWORD_HASH=$$apr1$$XXXX$$XXXXXXXXXXXXXXXXXXXX

# ==============================================================================
# Portainer
# ==============================================================================

# Bcrypt password hash for the Portainer admin account (username is always "admin").
# Generate with: docker run --rm httpd:2.4-alpine htpasswd -nbB "" "yourpassword" | cut -d ":" -f 2
# NOTE: do NOT double the $ here — this is passed as a CLI flag, not a Docker label.
PORTAINER_ADMIN_PASSWORD_HASH=$2y$05$XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ==============================================================================
# Pi-hole
# ==============================================================================

# Password for the Pi-hole web admin UI (http://<host>:8053/admin).
PIHOLE_WEBPASSWORD=changeme

# Upstream DNS servers Pi-hole forwards queries to (semicolon-separated).
# Defaults to Cloudflare (1.1.1.1) and Google (8.8.8.8) if not set.
PIHOLE_UPSTREAM_DNS=1.1.1.1;8.8.8.8

# ==============================================================================
# General
# ==============================================================================

# Container timezone. Used by Pi-hole for accurate log timestamps.
# Examples: UTC, America/New_York, Europe/London
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC